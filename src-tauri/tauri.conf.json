{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plasma Hub",
  "version": "0.1.0",
  "identifier": "com.camacho.plasmahub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plasma Hub",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: data: blob:; media-src 'self' plasma-media: asset: http://asset.localhost https: data: blob:; connect-src 'self' plasma-media: ipc: http://ipc.localhost http://localhost:* ws://localhost:* https: http: wss:; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCACHE/plasma-media/**",
          "$APPCACHE/telegram-media-cache/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$DOWNLOAD/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libc++1",
          "libc++abi1",
          "libunwind-18"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
